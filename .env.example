# IMS environment configuration (copy to .env)

# Kafka / Broker
IMS_KAFKA_BOOTSTRAP=redpanda:9092
IMS_KAFKA_TOPIC_SIGNALS=ims.signals
IMS_KAFKA_CONSUMER_GROUP=ims-worker

# Storage
IMS_POSTGRES_DSN=postgresql+asyncpg://ims:ims@postgres:5432/ims
IMS_MONGO_URI=mongodb://mongo:27017
IMS_MONGO_DB=ims
IMS_REDIS_URL=redis://redis:6379/0

# Debounce
IMS_DEBOUNCE_WINDOW_SECONDS=10
IMS_DEBOUNCE_THRESHOLD=100

# Rate limiting (ingest API)
IMS_RATE_LIMIT_PER_SEC_PER_IP=5000
IMS_RATE_LIMIT_PER_SEC_GLOBAL=20000
